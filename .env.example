# LLM Provider
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-oss-120b:free
LLM_TEMPERATURE=0.2

# GitHub
# Minimum PAT scopes: contents:read, pull_requests:write
# Classic PAT: repo scope (overprivileged but required for classic tokens)
# Fine-grained PAT recommended: contents:read + pull_requests:write
GITHUB_TOKEN=your_github_pat
WEBHOOK_SECRET=your_webhook_secret

# Review
CONFIDENCE_THRESHOLD=6
DRY_RUN=false

# Server
PORT=8080

# Queue (optional)
BUNQUEUE_DATA_PATH=data/bunqueue.db
